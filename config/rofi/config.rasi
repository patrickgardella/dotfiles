* {
    font: "FiraCode Nerd Font 11";
}

window {
    background-color: #000100;
    border: 2px;
    border-color: #31516C;
    border-radius: 8px;
    text-color: #E7DAD3;
}

mainbox {
    children: [ inputbar, listview ];
    padding: 8px;
    spacing: 8px;
}

inputbar {
    background-color: #948881;
    border-radius: 6px;
    padding: 6px;
    spacing: 8px;
    children: [ prompt, entry ];
}

prompt {
    text-color: #31516C;
    padding: 0 8px 0 0;
}

entry {
    text-color: #E7DAD3;
}

listview {
    background-color: transparent;
    spacing: 4px;
    padding: 0;
}

element {
    padding: 6px 8px;
    border-radius: 4px;
}

element normal {
    background-color: transparent;
    text-color: #E7DAD3;
}

element alternate {
    background-color: #000100;
}

element selected {
    background-color: #31516C;
    text-color: #000100;
}

element-icon {
    size: 24px;
}
