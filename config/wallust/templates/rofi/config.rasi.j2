* {
    font: "FiraCode Nerd Font 11";
}

window {
    background-color: {{ background }};
    border: 2px;
    border-color: {{ color4 }};
    border-radius: 8px;
    text-color: {{ foreground }};
}

mainbox {
    children: [ inputbar, listview ];
    padding: 8px;
    spacing: 8px;
}

inputbar {
    background-color: {{ color8 }};
    border-radius: 6px;
    padding: 6px;
    spacing: 8px;
    children: [ prompt, entry ];
}

prompt {
    text-color: {{ color4 }};
    padding: 0 8px 0 0;
}

entry {
    text-color: {{ foreground }};
}

listview {
    background-color: transparent;
    spacing: 4px;
    padding: 0;
}

element {
    padding: 6px 8px;
    border-radius: 4px;
}

element normal {
    background-color: transparent;
    text-color: {{ foreground }};
}

element alternate {
    background-color: {{ background }};
}

element selected {
    background-color: {{ color4 }};
    text-color: {{ background }};
}

element-icon {
    size: 24px;
}
